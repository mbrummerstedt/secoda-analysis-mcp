# Secoda API token — required
# Generate one at: Secoda → Settings → API
API_TOKEN=your-secoda-api-token-here

# Secoda API base URL — defaults to cloud instance
# Change this if you're on a self-hosted Secoda deployment
API_URL=https://app.secoda.co/api/v1/

# AI persona ID — optional
# Pin a specific Secoda AI persona for all ai_chat calls.
# Find persona IDs in Secoda → Settings → AI → Personas.
# Leave unset to use the workspace default persona.
# AI_PERSONA_ID=your-persona-id-here
